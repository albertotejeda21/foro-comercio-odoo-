<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_trade_cliente_form" model="ir.ui.view">
        <field name="name">trade.aduana.form</field>
        <field name="model">trade.aduana</field>
        <field name="arch" type="xml">

            <form string="Envío Formulario">
                <header>

                <!-- <field name="modo_transporte" widget="statusbar" clickable="True"/> -->
                <!-- <button name="nombre_funcion_python" string="enviar" type="object" class="oe_highlight"/> -->
                </header>
                <sheet>
                    <group>
                        <!-- Columna Izquierda -->


                
                
                        <group>
                        <field name="id_aduana"/>
                        <field name="codigo"/>
                        <field name = "ubicacion"/>
                        <field name = "tipo"/>
                        </group>
                        <!-- Columna Derecha -->
                        <group>
                            
                    <field name="id_exp"/>
        


    
                            
                        </group> 


                    </group>
                    
                </sheet>
            </form>
        </field>
    </record>


 <!-- 1. Acción -->
    <record id="action_trade_aduana" model="ir.actions.act_window">
    <field name="name">aduana</field>
    <field name="res_model">trade.aduana</field>
    <field name="view_mode">list,form</field>
    </record>

<record id="view_trade_exp_list" model="ir.ui.view">
    <field name="name">trade.aduana.list</field>
    <field name="model">trade.aduana</field>
    <field name="arch" type="xml">
        <list string="Envíos">
                        
                <field name="id_aduana"/>
                <field name="codigo"/>
                <field name = "ubicacion"/>
                <field name = "tipo"/>
        </list>
    </field>
</record>



<!-- 3. Submenú -->
<menuitem name="aduana" id="menu_trade_aduana" parent="menu_trade_root" action="action_trade_aduana"/>
</odoo>
