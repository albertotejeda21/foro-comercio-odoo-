<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_trade_cliente_form" model="ir.ui.view">
        <field name="name">trade.costumer.form</field>
        <field name="model">trade.customer</field>
        <field name="arch" type="xml">

            <form string="Envío Formulario">
                <header>

 
                <!-- <field name="modo_transporte" widget="statusbar" clickable="True"/> -->
                 <button name="nombre_funcion_python" string="enviar" type="object" class="oe_highlight"/> 
                </header>
                <sheet>
                    <group>
                        <!-- Columna Izquierda -->
                        <group>
                        <field name="razon_social"/>
                        <field name="vat"/>
                        <field name = "nombre_comercial"/>
                        <field name = "email"/>
                        <field name = "lname"/>

                        </group>
                        <!-- Columna Derecha -->
                    <!--   <group>
                            
                    <field name="master_bl"/>
                    <field name="id_exp"/> 

                    
                            
                        </group> -->


                    </group>
                    
                </sheet>
            </form>
        </field>
    </record>


 <!-- 1. Acción -->
    <record id="action_trade_customer" model="ir.actions.act_window">
    <field name="name">clientes</field>
    <field name="res_model">trade.customer</field>
    <field name="view_mode">list,form</field>
    </record>

<record id="view_trade_customer_list" model="ir.ui.view">
    <field name="name">trade.customer.list</field>
    <field name="model">trade.customer</field>
    <field name="arch" type="xml">
        <list string="Envíos">
            <field name="razon_social"/>
            <field name="vat"/>
            <field name="nombre_comercial"/>
            <field name="email"/>
            <field name="lname"/>


        </list>
    </field>
</record>



<!-- 3. Submenú -->
<menuitem name="Clientes" id="menu_trade_customer" parent="menu_trade_root" action="action_trade_customer"/>
</odoo>
