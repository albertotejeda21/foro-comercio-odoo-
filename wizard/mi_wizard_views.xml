<odoo>
   <data>
    <record id="view_mi_wizard_form" model="ir.ui.view">
        <field name="name">trade.cerrar.expediente.wizard.form</field>
        <field name="model">trade.cerrar.expediente.wizard</field>
        <field name="arch" type="xml">
            <form string="Cerrar Expedientes">
                <group>
                    <field name="fecha_cierre"/>
                    <field name="comentario"/>
                </group>
                <footer>
                    <button name="confirmar_cierre" string="Finalizar Expedientes" type="object" class="btn-primary"/>
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
  </record>

    <record id="action_mi_wizard" model="ir.actions.act_window">
        <field name="name">Cerrar expedientes masivamente</field>
        <field name="res_model">trade.cerrar.expediente.wizard</field> 
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="model_trade_exp"/> 
        <field name="binding_view_types">list</field>
    </record>

    <record id="action_trade_exp" model="ir.actions.act_window">
        <field name="name">Expediente</field>
        <field name="res_model">trade.exp</field>
        <field name="view_mode">list,form</field>
    </record>
    </data>
</odoo>
